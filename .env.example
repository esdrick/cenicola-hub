# ─── Database ─────────────────────────────────────────────────────────────────
# DEV (Docker local):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cenicola_hub"

# PROD (Supabase — Transaction pooler, puerto 6543):
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL solo se necesita en producción con Supabase (para prisma migrate deploy)
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# ─── Supabase (dejar vacío en dev local) ──────────────────────────────────────
# Found in: Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Admin inicial (solo para prisma db seed) ─────────────────────────────────
ADMIN_NAME="Admin Cenicola"
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="cambia-esta-password-segura"

# ─── Supabase Storage (dejar vacío en dev local) ──────────────────────────────
SUPABASE_BUCKET_PRODUCTS="product-photos"
SUPABASE_BUCKET_PAYMENTS="payment-photos"
SUPABASE_BUCKET_SHIPMENTS="shipment-photos"
SUPABASE_BUCKET_RECEIPTS="expense-receipts"
